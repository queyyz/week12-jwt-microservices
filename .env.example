TASK_DB_USER=task_user
TASK_DB_PASSWORD=CHANGE_THIS_PASSWORD

USER_DB_NAME=user_db
USER_DB_USER=user_user
USER_DB_PASSWORD=CHANGE_THIS_PASSWORD

GATEWAY_PORT=80
GRAFANA_PORT=3030