# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า secret ก่อนใช้งาน
# cp .env.example .env

JWT_SECRET=CHANGE_THIS_TO_RANDOM_32_CHARS_MINIMUM
JWT_EXPIRES=1h

